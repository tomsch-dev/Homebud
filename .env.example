# ─── Database (Kitchen Helper) ────────────────────────────────────────────────
POSTGRES_USER=kitchen_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=kitchen_helper

# ─── Backend ─────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_random_secret_key
DEFAULT_CURRENCY=EUR

# ─── Logto Auth (Cloud) ────────────────────────────────────────────────────
# LOGTO_ENDPOINT = Logto Cloud tenant URL (used by backend for JWKS validation)
# LOGTO_APP_ID   = SPA app ID from Logto Cloud console
LOGTO_ENDPOINT=https://3mplv2.logto.app
LOGTO_APP_ID=81ro7cpuddia051di3kij
LOGTO_API_RESOURCE=https://api.homebud.net

# ─── Logto M2M (for admin suspend/unsuspend via Management API) ──────────
LOGTO_M2M_APP_ID=your-m2m-app-id
LOGTO_M2M_APP_SECRET=your-m2m-app-secret
LOGTO_MANAGEMENT_API_RESOURCE=https://3mplv2.logto.app/api

# ─── OpenAI (for receipt scanning + AI chef) ────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key

# ─── Frontend (Vite build args — baked in at build time) ────────────────────
# Empty VITE_API_URL = same origin (nginx proxies /api/* to backend). No CORS issues.
VITE_API_URL=
VITE_LOGTO_ENDPOINT=https://3mplv2.logto.app
VITE_LOGTO_APP_ID=81ro7cpuddia051di3kij
VITE_LOGTO_API_RESOURCE=https://api.homebud.net

# ─── CORS / URLs ────────────────────────────────────────────────────────────
FRONTEND_URL=https://homebud.net
